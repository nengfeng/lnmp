# ============================================
# LNMP 一键安装脚本 .gitignore
# ============================================

# ============================================
# 日志文件
# ============================================
*.log
install.log
download.log
compile_error.log

# ============================================
# 下载的源码包 (运行时下载)
# ============================================
src/*.tar.gz
src/*.tar.xz
src/*.tar.bz2
src/*.tgz
src/*.zip

# 保留的文件 (补丁和证书)
!src/cacert.pem
!src/*.patch

# ============================================
# 二进制文件 (运行时生成)
# ============================================
# 注意: include/ois.* 是 IP 位置判断工具，需要保留
*.o
*.so
*.a

# ============================================
# 临时文件
# ============================================
*.tmp
*.temp
*.swp
*.swo
*~
.*.swp
.*.swo

# ============================================
# 备份文件
# ============================================
*.bak
*.backup
*.old
*_backup_*.sql

# ============================================
# IDE 和编辑器
# ============================================
# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs (PhpStorm, WebStorm, etc)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ============================================
# 操作系统
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================
# 敏感配置文件 (本地配置)
# ============================================
# 本地配置覆盖
options.conf.local
.env
.env.local
.env.*.local

# 密钥和凭据
*.pem
*.key
*.crt
!src/cacert.pem

# ============================================
# 数据目录 (运行时生成)
# ============================================
/data/
/backup/

# ============================================
# 测试和开发
# ============================================
test/
tests/
*.test.sh

# ============================================
# 文档生成
# ============================================
site/
docs/_build/

# ============================================
# 其他
# ============================================
# 压缩包
*.tar.gz
*.tar.xz
*.tar.bz2
*.zip
*.7z
*.rar

# 数据库备份
*.sql
*.sql.gz

# PHP Composer
vendor/
composer.lock

# Node.js
node_modules/
package-lock.json
yarn.lock

fix_*.sh

# ============================================
# 说明文档 (不加入版本管理)
# ============================================
# 新增的分析和建议文档，不需要提交到仓库
IMPROVEMENT_SUGGESTIONS.md
